project:
    name: skills
    version: 1.5.1
    versionPattern: SEMVER
    snapshot:
        enabled: false
        pattern: .*-SNAPSHOT
        label: early-access
        fullChangelog: false
    description: The CLI for the open agent skills ecosystem (Java port)
    longDescription: Java port of vercel-labs/skills CLI.
Install, manage, and discover agent skills for coding assistants.

    license: MIT
    inceptionYear: 2025
    copyright: 2025 Max Rydahl Andersen
    authors:
        Max Rydahl Andersen
    stereotype: NONE
    links:
        homepage: https://github.com/maxandersen/skills-java
        documentation: https://github.com/maxandersen/skills-java#readme
        license: https://spdx.org/licenses/MIT.html
        bugTracker: https://{{repoHost}}/{{repoOwner}}/{{repoName}}/issues
        vcsBrowser: https://{{repoHost}}/{{repoOwner}}/{{repoName}}
    extraProperties:
        versionMajor: 1
        versionMinor: 5
        versionPatch: 1
        versionNumber: 1.5.1
        versionWithUnderscores: 1_5_1
        versionWithDashes: 1-5-1
        versionNumberWithUnderscores: 1_5_1
        versionNumberWithDashes: 1-5-1
        effectiveVersionWithUnderscores: 1_5_1
        effectiveVersionWithDashes: 1-5-1
    languages:
        java:
            enabled: true
            version: 25
            groupId: sh.skills
            artifactId: jskills
            mainClass: sh.skills.Skills
            jvmOptions:
            environmentVariables:
            multiProject: false
 
platform:
 
